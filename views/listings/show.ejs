<% layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3><%= listing.title %></h3>
    </div>
    <div class="card col-6 offset-2">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing-image" style="height: 20rem;">
        <div class="card-img-overlay"></div>
        <div class="card-body">
            <p class="card-text">
                <%= listing.description %><br/>
                &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "Price not available" %> / night
                <%= listing.location %><br/>
                <%= listing.country %><br/>
            </p>
        </div>
    </div>
    <div class="col-1">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>
        <br/><br/>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-dark">Delete</button>
        </form> 
    </div>
    <hr>
    <!-- review -->
    <div class="col-8 offset-2">
        <h4>Leave a rieview</h4>
        <form action="/listings/<%= listing.id %>/reviews" class="mb-3" method="post">
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"></textarea>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
        </form>
    </div>
</div>
